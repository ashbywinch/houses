# Houses Configuration

# Google Sheets — paste the service account JSON as a single line
# HOUSES_GOOGLE_SHEETS_SERVICE_ACCOUNT={"type":"service_account","project_id":...}

# The spreadsheet ID from your sheet URL
# HOUSES_SHEET_ID=...

# API Keys
TFL_API_KEY=
HEIGIT_API_KEY=
PLACES_API_KEY=
OPENROUTER_API_KEY=

# National Rail Data Portal password (for UK rail fares lookup)
# Register at https://opendata.nationalrail.co.uk then set:
NATIONAL_RAIL_API_PASSWORD=

# Commute constants (defaults: 46 weeks, Simon 1d/wk, Lorena 2d/wk)
# HOUSES_WORKING_WEEKS_PER_YEAR=46
# HOUSES_WEEKLY_SIMON_TRIPS=1
# HOUSES_WEEKLY_LORENA_TRIPS=2
# HOUSES_WEEKLY_BRACKNELL_TRIPS=1
