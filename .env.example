# Houses Configuration

# Google Sheets — paste the service account JSON as a single line
# HOUSES_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":...}

# The spreadsheet ID from your sheet URL
# HOUSES_SHEET_ID=...

# These are set externally — not from this file
# TFL_API_KEY=...
# HEIGIT_API_KEY=...
