# Houses Configuration
# Copy to .env and fill in your values

# Google Sheets
# The ID from your sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
HOUSES_SHEET_ID=

# Path to service account JSON file (relative to project root)
HOUSES_GOOGLE_SERVICE_ACCOUNT_JSON=service-account.json

# OR paste the entire service account JSON inline (alternative to file)
# HOUSES_SERVICE_ACCOUNT_JSON_STRING={"type":"service_account",...}

# TravelTime API (transit commute times)
# Sign up: https://traveltime.com/free-api-trial
HOUSES_TRAVELTIME_APP_ID=
HOUSES_TRAVELTIME_API_KEY=

# OpenRouteService API (driving distance for petrol cost)
# Sign up: https://openrouteservice.org/dev/#/signup
HOUSES_ORS_API_KEY=

# Server
HOUSES_HOST=127.0.0.1
HOUSES_PORT=8080
HOUSES_RELOAD=true
